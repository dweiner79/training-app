# Backend environment variables
# Copy to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development

# Azure Entra ID (same tenant as frontend)
AZURE_TENANT_ID=your-entra-tenant-id
AZURE_CLIENT_ID=your-entra-app-client-id
AZURE_CLIENT_SECRET=your-entra-app-client-secret

# SharePoint
SHAREPOINT_SITE_URL=https://yourorg.sharepoint.com/sites/YourSite
SHAREPOINT_SITE_ID=your-sharepoint-site-id
SHAREPOINT_TRAINING_CATALOG_LIST_ID=list-guid
SHAREPOINT_TRAINING_EVENTS_LIST_ID=list-guid
SHAREPOINT_PROGRESS_LIST_ID=list-guid

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com
AZURE_OPENAI_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure AI Search (for RAG)
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your-search-api-key
AZURE_SEARCH_INDEX=hls-trainings

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
