# Vite + React frontend environment variables
# Copy this file to .env.local and fill in your values

# Azure Entra ID / MSAL
VITE_AZURE_CLIENT_ID=your-entra-app-client-id
VITE_AZURE_TENANT_ID=your-entra-tenant-id
VITE_AZURE_REDIRECT_URI=http://localhost:3000

# Backend API base URL (proxied in dev, direct in production)
VITE_API_BASE_URL=http://localhost:3000/api

# Copilot Studio (PVA) bot URL (from Power Platform portal)
VITE_PVA_BOT_URL=https://powerva.microsoft.com/webchat/...
